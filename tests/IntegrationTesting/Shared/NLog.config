<?xml version="1.0" encoding="utf-8" ?>
<!-- XSD manual extracted from package NLog.Schema: https://www.nuget.org/packages/NLog.Schema-->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd" 
	  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<targets async="true">
		<target name="Debug" xsi:type="File"
                openFileCacheTimeout="10"
                keepFileOpen="true"
                archiveNumbering="Date"
                archiveEvery="Day"
                archiveDateFormat="yyyyMMdd"
                archiveFileName="${basedir}/../Logs/${date:format=yyyyMMdd}/${logger}.Debug.log"
                fileName="${basedir}/../Logs/${date:format=yyyyMMdd}/${logger}.Debug.log"
                deleteOldFileOnStartup="false"
                layout="[${longdate}] ${message}"/>
		
		<target name="Info" xsi:type="File"
                openFileCacheTimeout="10"
                keepFileOpen="true"
                archiveNumbering="Date"
                archiveEvery="Day"
                archiveDateFormat="yyyyMMdd"
                archiveFileName="${basedir}/../Logs/${date:format=yyyyMMdd}/${logger}.Info.log"
                fileName="${basedir}/../Logs/${date:format=yyyyMMdd}/${logger}.Info.log"
                deleteOldFileOnStartup="false"
                layout="[${longdate}] ${message}"/>
		
		<target name="Warn" xsi:type="File"
                openFileCacheTimeout="10"
                keepFileOpen="true"
                archiveNumbering="Date"
                archiveEvery="Day"
                archiveDateFormat="yyyyMMdd"
                archiveFileName="${basedir}/../Logs/${date:format=yyyyMMdd}/${logger}.Warn.log"
                fileName="${basedir}/../Logs/${date:format=yyyyMMdd}/${logger}.Warn.log"
                deleteOldFileOnStartup="false"
                layout="[${longdate}] ${message}"/>
		
		<target name="Error" xsi:type="File"
                openFileCacheTimeout="10"
                keepFileOpen="true"
                archiveNumbering="Date"
                archiveEvery="Day"
                archiveDateFormat="yyyyMMdd"
                archiveFileName="${basedir}/../Logs/${date:format=yyyyMMdd}/${logger}.Error.log"
                fileName="${basedir}/../Logs/${date:format=yyyyMMdd}/${logger}.Error.log"
                deleteOldFileOnStartup="false"
                layout="[${longdate}] ${message}"/>
		
		<target name="Console" xsi:type="Console" layout="[${longdate}] ${message}"/>
		
		
	</targets>
	<!-- rules to map from logger name to target -->

	<rules>
		<logger ruleName="Debug" name="Server" minlevel="Trace" maxlevel="Error" writeTo="Debug"/>
		<logger ruleName="Info" name="Server" minlevel="Info" maxlevel="Info" writeTo="Info"/>
		<logger ruleName="Warn" name="Server" minlevel="Warn" maxlevel="Warn" writeTo="Warn"/>
		<logger ruleName="Error" name="Server" minlevel="Error" maxlevel="Error" writeTo="Error"/>
		<logger ruleName="Console" name="Server" minlevel="Warn" maxlevel="Error" writeTo="Console" enabled="false"/>
	</rules>
</nlog>