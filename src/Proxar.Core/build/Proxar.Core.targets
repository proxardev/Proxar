<Project>
	<!-- 编译前清理 generated 目录中的旧外部代理文件 -->
	<Target Name="ProxarCleanOldGeneratedFiles" BeforeTargets="CoreCompile">
		<ItemGroup>
			<OldGeneratedFiles Include="$(IntermediateOutputPath)generated\**\*_ExternalProxy.g.cs" />
		</ItemGroup>
		<Delete Files="@(OldGeneratedFiles)" />
		<Message Text="[Proxar] Cleaned @(OldGeneratedFiles->Count()) old generated external proxy files" Importance="high" />
	</Target>

	<!-- 编译后复制生成的外部代理文件 -->
	<Target Name="ProxarCopyExternalProxyCode" AfterTargets="CoreCompile">
		<!-- 清理目标目录中的旧文件 -->
		<ItemGroup>
			<OldOutputFiles Include="$(ProxarExternalProxyOutputPath)\**\*_ExternalProxy.g.cs" />
		</ItemGroup>
		<Delete Files="@(OldOutputFiles)" />

		<!-- 收集生成的新文件 -->
		<ItemGroup>
			<ExternalProxyFiles Include="$(IntermediateOutputPath)generated\**\*_ExternalProxy.g.cs" />
		</ItemGroup>

		<!-- 复制新文件 -->
		<Copy SourceFiles="@(ExternalProxyFiles)"
			  DestinationFolder="$(ProxarExternalProxyOutputPath)"
			  SkipUnchangedFiles="true"
			  Condition="'@(ExternalProxyFiles)' != ''" />

		<Message Text="[Proxar] Exported @(ExternalProxyFiles->Count()) external proxy files to $(ProxarExternalProxyOutputPath)" Importance="high" />
	</Target>
</Project>